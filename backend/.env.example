# Archivo: backend/.env.example

# Servidor
PORT=3001
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Seguridad JWT
# En producción usa un valor largo, único y secreto.
JWT_SECRET=pon_aqui_un_jwt_secret_seguro

# Base local opcional
DATA_PATH=./data/data.json

# Firebase / Firestore
# El proyecto actual está pensado para usar Firestore.
USE_FIREBASE=true

# Opción 1: credenciales por variables de entorno
FIREBASE_PROJECT_ID=tu_project_id
FIREBASE_CLIENT_EMAIL=tu_client_email
FIREBASE_PRIVATE_KEY=tu_private_key_con_saltos_de_linea

# Opción 2: credenciales por archivo local
# No subas este archivo a GitHub.
FIREBASE_SERVICE_ACCOUNT_PATH=